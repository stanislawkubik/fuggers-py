{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/tools/repo_hooks.py\" user-prompt-hook",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/tools/repo_hooks.py\" stop-hook",
            "statusMessage": "Checking repo gates",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
