{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/tools/validate_add_feature.py\" user-prompt-hook",
            "timeout": 15
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/tools/validate_public_api_refactor.py\" user-prompt-hook",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/tools/validate_add_feature.py\" stop-hook",
            "statusMessage": "Checking add-feature workflow",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/tools/validate_public_api_refactor.py\" stop-hook",
            "statusMessage": "Checking public API refactor workflow",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
